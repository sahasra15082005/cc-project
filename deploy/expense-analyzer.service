[Unit]
Description=Smart Expense Analyzer Streamlit App
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/opt/expense-analyzer
EnvironmentFile=/etc/expense-analyzer.env
ExecStart=/opt/expense-analyzer/.venv/bin/streamlit run app.py --server.port=8501 --server.address=0.0.0.0
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
